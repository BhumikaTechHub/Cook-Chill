generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String     @unique
  passwordHash String
  fullName     String?
  phone        String?
  dateOfBirth  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  favorites    Favorite[]
  ratings      Rating[]
  recipes      Recipe[]
  reviews      Review[]

  @@map("users")
}

model Recipe {
  id          String     @id @default(cuid())
  title       String
  description String
  ingredients String
  category    Category
  tags        String[]   @default([])
  authorId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  favorites   Favorite[]
  ratings     Rating[]
  author      User?      @relation(fields: [authorId], references: [id])
  reviews     Review[]

  @@index([authorId])
  @@map("recipes")
}

model Review {
  id          String           @id @default(cuid())
  userId      String
  recipeId    String?
  targetType  ReviewTargetType @default(RECIPE)
  targetTitle String?
  comment     String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  ratings     Rating[]
  recipe      Recipe?          @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recipeId])
  @@map("reviews")
}

model Favorite {
  id          String             @id @default(cuid())
  userId      String
  recipeId    String?
  targetType  FavoriteTargetType @default(RECIPE)
  targetTitle String
  targetImage String?
  createdAt   DateTime           @default(now())
  recipe      Recipe?            @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId, targetTitle])
  @@index([userId])
  @@index([recipeId])
  @@map("favorites")
}

model Rating {
  id          String           @id @default(cuid())
  userId      String
  recipeId    String?
  reviewId    String?
  targetType  RatingTargetType @default(RECIPE)
  targetTitle String?
  value       Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  recipe      Recipe?          @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  review      Review?          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recipeId])
  @@index([reviewId])
  @@map("ratings")
}

enum Category {
  Breakfast
  Lunch
  Dinner
  Dessert
}

enum ReviewTargetType {
  RECIPE
  ENTERTAINMENT
  GENERAL
}

enum FavoriteTargetType {
  RECIPE
  ENTERTAINMENT
}

enum RatingTargetType {
  RECIPE
  ENTERTAINMENT
}

    <!-- FAQ accordion: answers hidden by default, toggle visible on click -->
    <section class="container-max section" aria-labelledby="faq-heading">
        <div class="end">
            <h2>Everything You Need to Know: Explore Our Comprehensive FAQs</h2>
        </div>
        
            <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="faq2">How do I get feedback on my
                    recipe or review?</button>
                <div id="faq2" class="faq-answer" hidden>
                    <p>Community members can comment and rate your submission. To increase visibility, share quality
                        images and clear steps — higher engagement brings more feedback.</p>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="faq3">What types of recipes and
                    entertainment reviews can I submit?</button>
                <div id="faq3" class="faq-answer" hidden>
                    <p>Submit any home-cooked recipes, snacks, drinks, or entertainment reviews (concerts, movies,
                        shows) that follow our community guidelines. Avoid copyrighted or commercial content without
                        permission.</p>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="faq4">How do you choose featured
                    recipes or reviews?</button>
                <div id="faq4" class="faq-answer" hidden>
                    <p>Featured items are chosen based on quality, originality, clear instructions, great photos, and
                        positive community engagement. Staff picks and seasonal highlights also appear.</p>
                </div>
            </div>
        </div>
    </section>

    <style>
        .faq {
            max-width: 980px;
        }

        .faq-item {
            border-bottom: 1px solid #e6e6e6;
        }

        .faq-question {
            width: 100%;
            text-align: left;
            background: transparent;
            border: none;
            padding: 18px 6px;
            font-size: 28px;
            font-weight: 700;
            color: #16324a;
            cursor: pointer;
        }

        .faq-question:hover {
            color: #f4a23e;
        }

        .faq-question:focus {
            outline: 3px solid rgba(244, 162, 62, .15);
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height .26s ease;
            padding: 0 6px;
        }

        .faq-answer p {
            margin: 0 0 12px 0;
            line-height: 1.5;
            color: #333;
        }

        @media (max-width:720px) {
            .faq-question {
                font-size: 20px;
            }
        }
    </style>

    <script>
        (function () {
            const buttons = document.querySelectorAll('.faq-question');
            buttons.forEach(btn => {
                btn.addEventListener('click', () => {
                    const expanded = btn.getAttribute('aria-expanded') === 'true';
                    const content = document.getElementById(btn.getAttribute('aria-controls'));
                    if (!content) return;
                    if (expanded) {
                        // collapse
                        btn.setAttribute('aria-expanded', 'false');
                        content.style.maxHeight = content.scrollHeight + 'px';
                        requestAnimationFrame(() => { content.style.maxHeight = '0px'; });
                        content.addEventListener('transitionend', function handler() { content.hidden = true; content.removeEventListener('transitionend', handler); });
                    } else {
                        // expand
                        content.hidden = false;
                        btn.setAttribute('aria-expanded', 'true');
                        const h = content.scrollHeight;
                        content.style.maxHeight = '0px';
                        requestAnimationFrame(() => { content.style.maxHeight = h + 'px'; });
                    }
                });
            });
        })();
    </script>


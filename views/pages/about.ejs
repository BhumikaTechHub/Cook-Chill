<%- include('../partials/head', { title, stylesheet: '/CSS/AboutUs.css' }) %>

<header class="header">
    <h1>Cook and Chill</h1>
    <p>Your one-stop platform to discover, share, and review recipes, movies, and more!</p>
</header>

<main class="about-container">
    <section class="mission">
        <h2>Our Mission</h2>
        <p>At Cook and Chill, our mission is to create a fun and interactive space where food lovers and entertainment enthusiasts can connect, discover, and enjoy the latest trends in recipes, movies, shows, and books.</p>
    </section>

    <section class="features">
        <h2>Key Features</h2>
        <ul>
            <li><strong>Browse and Search:</strong> Easily browse and search for recipes, movies, and more.</li>
            <li><strong>Submit and Review:</strong> Share your favorite recipes or review movies, shows, and books.</li>
            <li><strong>Rate and Comment:</strong> Engage with other users by rating and commenting on their submissions.</li>
        </ul>
    </section>

    <section class="community">
        <h2>Join the Community</h2>
        <p>We believe in building a community where everyone has a voice. Whether you're a foodie, movie buff, or just looking for something new, Cook and Chill is here for you!</p>
        <button type="button">Join Us</button>
    </section>
</main>

<%- include('../partials/minimal-footer') %>

<script src="/JS/AboutUs.js"></script>
<%- include('../partials/foot') %>

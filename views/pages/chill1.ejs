<%- include('../partials/head', { title, stylesheet: '/CSS/chill1.css' }) %>

<header class="header">
    <h1 class="site-title">Entertainment Discover</h1>
    <nav class="header-nav">
        <a href="#section1" class="header-button">Search</a>
        <a href="#section2" class="header-button">Discover</a>
    </nav>
</header>

<main class="main-content">
    <section class="search-discover-box" id="section1">
        <div class="content-part">
            <h2>Search, Discover, Decide</h2>
            <p>Use our platform to find your next favorite movie or show.</p>
        </div>
        <div class="image-part">
            <a href="/chill/discover">
                <img src="/IMAGES/netflix.jpeg" alt="Search Discover Image" class="info-image" style="max-width: 63%; border-radius: 20px; height: 38%;">
            </a>
        </div>
    </section>

    <section class="info-section" id="section2">
        <div class="info-box">
            <div class="image-placeholder">
                <a href="/chill/reviews">
                    <img src="/IMAGES/chill1 pic 2.jpeg" alt="Let's Talk Entertainment Image" class="info-image">
                </a>
            </div>
            <p class="info-text">Let's talk entertainment.</p>
        </div>
    </section>

    <footer class="footer">
        <p>Ready To Discover?</p>
        <div class="footer-links">
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Service</a>
        </div>
    </footer>
</main>

<script src="/JS/chill1.js"></script>
<%- include('../partials/foot') %>

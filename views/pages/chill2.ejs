<%- include('../partials/head', { title, stylesheet: '/CSS/chill2.css' }) %>

<header class="header">
    <div class="logo img">
        <img src="/IMAGES/logo.png" alt="Logo">
    </div>
    <nav class="nav">
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="#genres">Genres</a></li>
            <li><a href="#top-picks">Top Picks</a></li>
            <li><a href="#recommendations">Recommendations</a></li>
            <li><a href="/about">About</a></li>
            <li class="profile-icon">
                <a href="/profile"><span>&#128100;</span></a>
            </li>
        </ul>
    </nav>
</header>

<main class="main-content">
    <section class="search-section">
        <input type="text" placeholder="Search movies, shows, genres, or languages" class="search-input">
        <div class="filter-buttons">
            <button type="button">Action</button>
            <button type="button">Thriller</button>
            <button type="button">English</button>
            <button type="button">Hindi</button>
            <button type="button">Punjabi</button>
            <button type="button">2023</button>
            <button type="button">2021</button>
            <button type="button">TV Show</button>
            <button type="button">Movie</button>
            <button type="button">Web Series</button>
            <button type="button">Comedy</button>
        </div>
    </section>

    <div class="toolbar">
        <div class="toolbar-group">
            <label for="movieSort">Sort picks</label>
            <select id="movieSort">
                <option value="featured">Featured</option>
                <option value="az">A to Z</option>
                <option value="za">Z to A</option>
                <option value="newest">Newest Year</option>
            </select>
            <button type="button" id="clearMovieFilters" class="ghost-button">Clear Filters</button>
        </div>
        <div class="toolbar-group">
            <span id="movieResultsCount">12 picks</span>
        </div>
    </div>
    <p id="moviePageStatus" class="status-message" hidden></p>

    <section class="movie-section comedy-section" id="genres">
        <h2>Top 10 Comedy</h2>
        <div class="movie-list">
            <img src="/IMAGES/dhamaal.jpeg" alt="Dhamaal">
            <img src="/IMAGES/little man.jpeg" alt="Little Man">
            <img src="/IMAGES/panchayat.jpeg" alt="Panchayat">
        </div>
    </section>

    <section class="movie-section action-section" id="top-picks">
        <h2>Top 10 Action</h2>
        <div class="movie-list">
            <img src="/IMAGES/andhadun.jpg" alt="Andhadhun">
            <img src="/IMAGES/mirzapur.jpeg" alt="Mirzapur">
            <img src="/IMAGES/behind her eyes.jpeg" alt="Behind Her Eyes">
        </div>
    </section>

    <section class="movie-section recommendation-section" id="recommendations">
        <h2>Recommendations</h2>
        <div class="movie-list">
            <img src="/IMAGES/puaada.jpeg" alt="Puaada">
            <img src="/IMAGES/kill.jpg" alt="Kill">
            <img src="/IMAGES/radhe.jpeg" alt="Radhe">
        </div>
    </section>

    <section class="movie-section favorite-section">
        <h2>All-Time Favorites</h2>
        <div class="movie-list">
            <img src="/IMAGES/3 idiots.jpeg" alt="3 Idiots">
            <img src="/IMAGES/bahubali 2.jpeg" alt="Bahubali 2">
            <img src="/IMAGES/carry on jatta 2.jpeg" alt="Carry On Jatta 2">
        </div>
    </section>
</main>

<script src="/JS/chill2.js"></script>
<%- include('../partials/foot') %>
